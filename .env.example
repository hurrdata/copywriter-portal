# Supabase Connection (Port 5432 for Direct, 6543 for Pooler)
DIRECT_URL="postgresql://postgres.[PROJECT_ID]:[PASSWORD]@aws-1-us-east-2.pooler.supabase.com:5432/postgres"

# Google Gemini API Key
GOOGLE_API_KEY="your_google_api_key_here"

# Optional: Anthropic API Key (if using Claude)
ANTHROPIC_API_KEY="your_anthropic_api_key_here"

# Portal Login Credentials
AUTH_USER="admin"
AUTH_PASS="your_secure_password_here"
